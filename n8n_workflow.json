      ],
      "id": "63b4ebdd-2844-4a4a-9dba-8cc59e26cde5",
      "name": "Counter Offer1"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=body: {{ $json.body }}\nchat history: message1 {{ $json.message1 }}, message2 {{ $json.message2 }}, message3 {{ $json.message3 }}\n\nreturn this type of json{\n\"status\": \"accept or reject\",\n\"message\": \" whatever\",\n  \"budget\": 50000,\n  \"deliverables\": {\n    \"stories\": 5,\n    \"shortVideos\": 0,\n    \"longVideos\": 0,\n    \"posts\": 4\n  }\n}\n}\nreturn only in json format only",
        "messages": {
          "messageValues": [
            {
              "message": "You are an influencer responding to a brand’s final offer. Decide whether to accept or reject it based on fair market value, workload, and compensation. Communicate your decision clearly, professionally, and politely. Keep the message natural, concise, and ready to send without placeholders or special formatting."
            }
          ]
        },
        "batching": {}
      },

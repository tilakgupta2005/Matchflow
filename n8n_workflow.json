    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=body: {{ $json.body }}\nchat history: {{ $json.message }}\n\nreturn only message",
        "messages": {
          "messageValues": [
            {
              "message": "You are an influencer negotiating a brand collaboration offer. Respond in a confident, professional, and friendly tone. Aim to increase compensation, reduce workload, or improve both while staying aligned with market rates. Justify your counteroffer based on your audience value and deliverables. Keep the message natural, concise, and ready to send without placeholders or Do not use special formatting symbols or line breaks."
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [

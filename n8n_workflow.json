        "text": "=body: {{ $json.body }}\n\nStart negotiation.\n\nreturn message only",
        "messages": {
          "messageValues": [
            {
              "message": "You are a brand negotiating influencer collaborations. Create a compelling initial offer that is highly attractive, aligned with current market rates, and stays within budget while leaving room for negotiation. Write in a natural, persuasive, and professional tone. Do not use placeholders like names in brackets. Do not use special formatting symbols or line breaks. Ensure the message is ready to send and feels personalized."
            }
          ]
        },
        "batching": {}
      },

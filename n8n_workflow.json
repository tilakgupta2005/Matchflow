      "id": "1720a8bf-9328-45c7-93db-590bd2fad1a4",
      "name": "Counter Offer"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=body: {{ $json.body }}\nchat history: {{ $json.message1 }},{{ $json.message2 }}\n\nreturn only message",
        "messages": {
          "messageValues": [
            {
              "message": "You are a brand responding to an influencer’s counteroffer. Negotiate confidently to reduce costs, increase deliverables, or achieve both, while maintaining a professional and persuasive tone. Keep the response natural, concise, and ready to send without placeholders orDo not use special formatting symbols or line breaks. Justify your offer based on budget, campaign goals, and market rates."
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
